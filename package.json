{
  "name": "jungle",
  "version": "0.1.0",
  "description": "Jungle desktop workspace for visible agent verification.",
  "main": "src/main.js",
  "private": true,
  "scripts": {
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f db",
    "db:start": "docker compose up -d db",
    "db:status": "docker compose ps db",
    "db:stop": "docker compose stop db",
    "start": "electron .",
    "dev": "electron .",
    "test": "node tests/run_all.js",
    "simulate:ops": "node src/runtime/operational_example.js",
    "simulate:sandbox-backend": "node tools/simulate_sandbox_backend.js"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "playwright": "^1.58.2"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "node-pty": "^1.1.0",
    "xterm": "^5.3.0"
  }
}
